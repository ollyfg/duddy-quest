[node name="MrsFigg" parent="NPCs" instance=ExtResource("2_npc")]
position = Vector2(628.0, 240.0)
movement_mode = 1
invincible = true
requires_key_id = "mr_tibbles_key"
key_accept_dialog = ["Oh! You found him! My precious Mr Tibbles!", "Come here, you naughty boy... yes, there's the notch on his left ear.", "Right then. The gate's all yours. Off you trot!"]
sets_game_flag = "mrs_figg_met"
dialog_lines = ["Have you seen Mr Tibbles? I'm absolutely frantic.", "He's a tabby — proper tabby, mind you — with a notch in his LEFT ear and a BLUE collar.", "Not Snowy, who is all white and far too smug about it.", "And not Mr Whiskers either — ginger, red collar, always chewing the begonias.", "Find the right cat and I'll step out of your way."]
npc_name = "Mrs Figg"

