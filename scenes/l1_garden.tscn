[node name="MrsFigg" parent="NPCs" instance=ExtResource("2_npc")]
position = Vector2(592.0, 160.0)
movement_mode = 1
invincible = true
requires_interact = true
requires_key_id = "mr_tibbles_key"
key_accept_dialog = ["Oh! You found him! My precious Mr Tibbles!", "Come here, you naughty boy... yes, there's the notch on his left ear.", "Right then. The gate's all yours. Off you trot!"]
sets_game_flag = "mrs_figg_met"
dialog_lines = ["Oh hello Dudley! Have you seen Mr Tibbles around? I seem to have lost him.", "You do know what he looks like, don't you? Proper tabby — notch in his LEFT ear and a BLUE collar."]
dialog_pools = [["Here's a picture — oh doesn't he just look adorable. Reminds me of Tibbles. The first one mind you. Let me just find his photo...", "Oh there we are, yes! Tibbles had quite the personality, he followed his mother like that. Now where's her photo...", "*You manage to sneak away while she shuffles through her photos*."], ["Mr Tibbles has four brothers, you know. Mr Pebbles, Mr Nibbles, Mr Bubbles, and Mr Wobbles. Wobbles only had three legs after the incident with the garden shears, poor dear...", "They all had that notch in the left ear. I never quite worked out how. Could be genetic, I suppose, or the same fence post...", "*You back away as she descends into cataloguing the fence post in exhaustive detail*."], ["Mr Tibbles is named after his grandmother, of course. Old Mrs Tibbles. But she's not the original — the FIRST Tibbles was technically a Mr as well...", "Which caused no end of confusion with the neighbours. The Thompsons at number nine had a Tibbles too, but theirs was all black. No class whatsoever.", "*You nod and edge towards the garden gate while she explains the full Tibbles naming tradition*."], ["Mr Tibbles is a very particular cat. He likes his dinner at exactly 4:15 — not 4:14, not 4:16. Last Tuesday I was one minute late and he knocked my teacup off the counter deliberately.", "Also he won't sit on the floral cushions, only the plain ones. I've had to rearrange my entire sitting room for that cat.", "*You slip through the garden gate while she fondly recounts Mr Tibbles' latest act of furniture sabotage*."]]
npc_name = "Mrs Figg"

