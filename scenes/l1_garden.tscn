[node name="MrsFigg" parent="NPCs" instance=ExtResource("2_npc")]
position = Vector2(896.0, 320.0)
movement_mode = 1
invincible = true
requires_interact = true
requires_key_id = "mr_tibbles_key"
key_accept_dialog = ["Oh! You found him! My precious Mr Tibbles!", "Come here, you naughty boy... yes, there's the notch on his left ear.", "Right then. The gate's all yours. Off you trot!"]
sets_game_flag = "mrs_figg_met"
dialog_lines = ["Oh hello Dudley! Have you seen Mr Tibbles around? I seem to have lost him.", "You do know what he looks like, don't you? Proper tabby — notch in his LEFT ear and a BLUE collar."]
dialog_pools = [["Here's a picture — oh doesn't he just look adorable. Reminds me of Tibbles. The first one mind you. Let me just find his photo...", "Oh there we are, yes! Tibbles had quite the personality, he followed his mother like that. Now where's her photo..."], ["Mr Tibbles has four brothers, you know. Mr Pebbles, Mr Nibbles, Mr Bubbles, and Mr Wobbles. Wobbles only had three legs after the incident with the garden shears, poor dear...", "They all had that notch in the left ear. I never quite worked out how. Could be genetic, I suppose, or the same fence post..."], ["Mr Tibbles is named after his grandmother, of course. Old Mrs Tibbles. But she's not the original — the FIRST Tibbles was technically a Mr as well...", "Which caused no end of confusion with the neighbours. The Thompsons at number nine had a Tibbles too, but theirs was all black. No class whatsoever."], ["Mr Tibbles is a very particular cat. He likes his dinner at exactly 4:15 — not 4:14, not 4:16. Last Tuesday I was one minute late and he knocked my teacup off the counter deliberately.", "Also he won't sit on the floral cushions, only the plain ones. I've had to rearrange my entire sitting room for that cat."], ["Mr Tibbles was once on the television, you know. Not deliberately — he walked into shot during a local news broadcast.", "They tried to shoo him off but he sat there for four minutes. That was his most dignified moment, I think."], ["Every cat I've ever had has been called Tibbles. It started with my mother's cat, then mine, then the one after that...", "Once the RSPCA inspector said 'which one is Tibbles' and I said 'all of them, broadly.'"], ["Mr Tibbles gets into fights with that ginger tom from number thirteen. Always the same story — he comes home with a torn ear.", "I've written to the Thompsons about it twice. They say it's Mr Whiskers that starts it. I say: Mr Tibbles wouldn't hurt a fly."], ["I found Mr Tibbles on the kitchen counter last Tuesday helping himself to my smoked salmon.", "He looked at me for a full five seconds and then went back to eating it. You have to respect the audacity, really."], ["Mr Tibbles has learned to open the bathroom door. I still don't know how. He can't work doorknobs, but latches apparently are no obstacle.", "I've considered getting a cat flap, but frankly he seems to prefer the bathroom. It is the warmest room."]]
dialog_suffix = ["*You manage to sneak away while she shuffles through her photos*."]
npc_name = "Mrs Figg"

