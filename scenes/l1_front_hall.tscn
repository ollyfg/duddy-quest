[node name="UncleVernon" parent="NPCs" instance=ExtResource("2_npc")]
position = Vector2(352.0, 176.0)
movement_mode = 1
dialog_lines = []
dialog_pools = [["PERFECTLY normal household! Perfectly NORMAL!", "There are no letters. There WERE no letters. There WILL be no letters.", "I don't know what you think you saw, boy, but I suggest you forget it immediately."], ["I won't have it! There will be NO nonsense in this house!", "Normal people! Normal jobs! Normal EVERYTHING! That is what we ARE!", "If I hear ONE more word about any of this, you're sleeping in the other cupboard."], ["That lot! THOSE people! They are NOT our kind, do you understand?", "YOUR kind of people just — there IS no 'your kind'! You're a DURSLEY. Remember that!", "*Uncle Vernon's face turns an impressive shade of puce.*"], ["The neighbours! If the NEIGHBOURS knew — they must NEVER know!", "Marge is visiting soon. You will be NORMAL. You will be PERFECTLY NORMAL.", "So help me, if I see one more owl in this neighbourhood..."], ["ABNORMAL! COMPLETELY ABNORMAL! And I will NOT have it in MY house!", "There is NOTHING going on. There is NOTHING unusual. We are a PERFECTLY NORMAL FAMILY.", "If ANYONE asks — the neighbours, your teachers, ANYONE — you say NOTHING. Are we clear?!"], ["Those people! Always interfering! Always MEDDLING!", "A Dursley does NOT associate with — with THEIR sort! You hear me? NOT!", "We gave you a HOME! A PERFECTLY NORMAL HOME! And THIS is how you repay us?!"], ["There will be NO magic here! NONE! Not now, not EVER!", "We are NORMAL. We have ALWAYS been normal. We will CONTINUE to be normal.", "I will NOT have it! Not under my roof! NOT. ONE. BIT!"], ["You think this is FUNNY?! Do you?! Well I assure you, it is NOT funny!", "Everything — EVERYTHING — is under control. Perfectly normal. Moving on.", "*Uncle Vernon grips the newspaper so hard it begins to tear.*"], ["I have put up with A GREAT DEAL, and I will put up with it NO LONGER!", "Normal families don't have OWL POST. Normal families don't have LETTERS from SCHOOLS!", "*Uncle Vernon's moustache is vibrating slightly.*"]]
npc_name = "Uncle Vernon"

