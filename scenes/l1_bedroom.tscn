[node name="HogwartsNote" parent="NPCs" instance=ExtResource("2_npc")]
position = Vector2(192.0, 256.0)
movement_mode = 1
dialog_lines = ["What on earth... A letter. Addressed to D. DURSLEY (THE LARGER ONE).", "HOGWARTS SCHOOL OF WITCHCRAFT AND WIZARDRY", "Dear Mr. Dursley, We are pleased to inform you that you have been accepted at Hogwarts School of Witchcraft and Wizardry.", "Please find enclosed a list of all necessary books and equipment. Term begins on 1 September.", "We await your owl by no later than 31 July. Yours sincerely, Minerva McGonagall, Deputy Headmistress.", "A Hogwarts letter! FOR ME! Mum has been hiding this for years!"]
npc_name = "Hogwarts Letter"
custom_sprite_color = Color(0.96, 0.94, 0.82, 1)

