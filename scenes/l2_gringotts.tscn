[node name="GoblinClerk" parent="NPCs" instance=ExtResource("2_npc")]
position = Vector2(368.0, 144.0)
movement_mode = 1
npc_name = "Goblin Clerk"
custom_sprite_color = Color(0.4, 0.65, 0.3, 1)
requires_flag = "l2_has_wizard_money"
pre_flag_dialog = ["Exchange? Certainly. The rate is 3 Galleons per pound.", {"text": "How many pounds would you like to exchange?", "options": [{"label": "That seems fair.", "next": ["Excellent choice. I will process that immediately.", "That will be... all of it. Here is your one Galleon.", "(The Goblin takes all your Muggle money.)", "Come back if you change your mind. The rate is always 3 Galleons per pound."]}, {"label": "That can't be right.", "flag": "l2_goblin_challenged", "next": ["The rate board? It is... being cleaned.", "Fine. The ACTUAL rate is 17 pounds to the Galleon.", "Processing fee of... let me find the schedule...", {"text": "I seem to have misplaced the fee schedule...", "options": [{"label": "I can see it right there.", "flags": ["l2_goblin_caught", "l2_has_wizard_money"], "next": ["...Very well. Standard rate. No extras.", "Here is your wizard money. Good day."]}, {"label": "Take your time.", "next": ["How very kind. The fee comes to... most of it.", "(The Goblin pockets a large portion of your money.)", "Come back if you would like to try again."]}]}]}]}]
dialog_lines = ["Is there anything else?"]
